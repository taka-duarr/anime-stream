    "@react-navigation/native": "^7.1.26",
    "@react-navigation/native-stack": "^7.9.0",
    "axios": "^1.13.2",
    "axios-retry": "^4.5.0",
    "expo": "^56.0.12",
    "expo-av": "~16.0.8",
    "expo-image": "~56.0.11",
    "expo-image-picker": "~56.0.18",
    "expo-keep-awake": "~56.0.3",
    "expo-linear-gradient": "~56.0.4",
    "expo-screen-orientation": "~56.0.5",
    "expo-status-bar": "~56.0.4",
    "expo-video": "~56.1.4",
    "react": "19.2.3",
