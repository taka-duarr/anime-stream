{
  "expo": {
    "name": "MyAnime",
    "slug": "myanime-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logo.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#121212"
    },
    "newArchEnabled": true,
    "android": {
      "package": "com.myanime.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/logo.png",
        "backgroundColor": "#FF4757"
      },
      "usesCleartextTraffic": true,
      "permissions": [
        "INTERNET",
        "ACCESS_NETWORK_STATE"
      ]
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.myanime.app"
    },
    "web": {
      "favicon": "./assets/logo.png"
    },
    "plugins": [
      "expo-video",
      "expo-image",
      "expo-status-bar"
    ],
    "extra": {
      "eas": {
        "projectId": "de8c0b27-e0f7-4f65-b89b-1e02b25fa5c4"
      }
    }
  }
}
